GEX_GAMMA_DATA_DIR=/var/lib/gex-gamma
GEX_GAMMA_DB_PATH=/var/lib/gex-gamma/gex_gamma.db
GEX_SNAPSHOT_PATH=/var/lib/gex-gamma/snapshots/latest.json
GEX_GAMMA_CACHE_BACKEND=inprocess
MASSIVE_API_KEY=
MASSIVE_API_BASE=https://api.massive.com
MASSIVE_RATE_PER_MIN=4.0
GEX_RISK_FREE_RATE=0.04
# Optional: write to Supabase Postgres (transaction pooler, port 6543) instead of SQLite
# DATABASE_URL=postgresql://...pooler.supabase.com:6543/postgres?sslmode=require
